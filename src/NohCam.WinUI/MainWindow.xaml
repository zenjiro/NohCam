<Window
    x:Class="NohCam.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NohCam">
    <Grid Background="#1F2937">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#111827" Padding="20">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="NohCam" Foreground="White" FontSize="28" FontWeight="SemiBold" />
                <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Foreground="#9CA3AF" Text="Starting camera..." />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Padding="20" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="Black" CornerRadius="12" Padding="12">
                <Grid>
                    <MediaPlayerElement
                        x:Name="PreviewElement"
                        AreTransportControlsEnabled="False"
                        Stretch="Uniform" />
                    <TextBlock
                        x:Name="PreviewPlaceholderTextBlock"
                        Text="Preview surface"
                        Foreground="#6B7280"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#111827" CornerRadius="12" Padding="14">
                <StackPanel Spacing="8">
                    <TextBlock Text="Camera Status" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="DeviceTextBlock" Text="Device: (none)" TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="PreviewStateTextBlock" Text="Preview: not started" TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="14" />

                    <Border Height="1" Background="#374151" Margin="0,2" />

                    <TextBlock Text="Face Tracking" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="FaceDetectedTextBlock" Text="Detected: No" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="FaceYawTextBlock" Text="Yaw: 0.00" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="FacePitchTextBlock" Text="Pitch: 0.00" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="FaceRollTextBlock" Text="Roll: 0.00" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="FaceCenterTextBlock" Text="Center: (0.50, 0.50)" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="BlendshapeCountTextBlock" Text="Blendshapes: 0" Foreground="#9CA3AF" FontSize="14" />

                    <Border Height="1" Background="#374151" Margin="0,2" />

                    <TextBlock Text="Pose Tracking" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="PoseDetectedTextBlock" Text="Detected: No" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="PoseScoreTextBlock" Text="Score: 0.00" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="PoseWristsTextBlock" Text="Wrists (L/R): (0.0, 0.0) / (0.0, 0.0)" Foreground="#9CA3AF" FontSize="14" />

                    <Border Height="1" Background="#374151" Margin="0,2" />

                    <TextBlock Text="Hand Tracking" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="LeftHandDetectedTextBlock" Text="Left: No" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="LeftWristTextBlock" Text="Left Wrist: (0.0, 0.0, 0.0)" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="RightHandDetectedTextBlock" Text="Right: No" Foreground="#9CA3AF" FontSize="14" />
                    <TextBlock x:Name="RightWristTextBlock" Text="Right Wrist: (0.0, 0.0, 0.0)" Foreground="#9CA3AF" FontSize="14" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
